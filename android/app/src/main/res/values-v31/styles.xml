<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ (API 31+): оба стиля используют DeviceDefault,
         который на API 31+ является Material3-темой и передаёт
         SystemColor.platformProvidesSystemColors = true -->
    <style name="LaunchTheme" parent="@android:style/Theme.DeviceDefault.NoActionBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.DeviceDefault.NoActionBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>
